<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.yuebai.flowbot-worker</string>
  <key>WorkingDirectory</key>
  <string>__APP_ROOT__</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>__APP_ROOT__/scripts/dev-flowbot-worker.sh</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>StandardOutPath</key>
  <string>/tmp/yuebai-flowbot-worker.log</string>
  <key>StandardErrorPath</key>
  <string>/tmp/yuebai-flowbot-worker.err.log</string>
</dict>
</plist>
