[Unit]
Description=Yuebai AI Tool Platform
After=network.target

[Service]
Type=simple
User=__DEPLOY_USER__
WorkingDirectory=__INSTALL_ROOT__/current
Environment=AI_ADMIN_CONFIG_PATH=__INSTALL_ROOT__/shared/ai-admin.json
ExecStart=/bin/bash __INSTALL_ROOT__/current/scripts/dev-ai-admin.sh
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
