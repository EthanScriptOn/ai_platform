INSTALL_ROOT=/opt/yuebai-ai-platform
DEPLOY_USER=yfduser
AI_ADMIN_HOST=0.0.0.0
AI_ADMIN_PORT=8788
AI_ADMIN_ENV_FILE=/opt/yuebai-ai-platform/shared/.env
FLOWBOT_HOST=127.0.0.1
FLOWBOT_ROOM_ID=154085252767863
FLOWBOT_BASE_URL=http://127.0.0.1:3010
FLOWBOT_DATA_DIR=/opt/yuebai-ai-platform/data/customer-bot-data
FLOWBOT_KNOWLEDGE_DIR=/opt/yuebai-ai-platform/current/apps/flowbot-knowledge
FLOWBOT_AGENT_BASE_URL=http://127.0.0.1:3010/flowbot/agent
# file 为本地默认模式；生产环境可改为 mysql，与线上 Flowbot runtime 存储保持一致。
FLOWBOT_STORAGE_BACKEND=file
FLOWBOT_MYSQL_HOST=127.0.0.1
FLOWBOT_MYSQL_PORT=3306
FLOWBOT_MYSQL_DATABASE=flowbot_runtime
FLOWBOT_MYSQL_USER=flowbot_app
FLOWBOT_MYSQL_PASSWORD=
FLOWBOT_MYSQL_BIN=/opt/yuebai-ai-platform/current/scripts/mysql-via-docker.sh
FLOWBOT_MYSQL_AUTO_MIGRATE=1
RAGFLOW_BASE_URL=http://127.0.0.1:8080
RAGFLOW_AGENT_ID=
RAGFLOW_SHARE_AUTH=
RAGFLOW_LOGIN_EMAIL=
RAGFLOW_LOGIN_PASSWORD=
RAGFLOW_LOGIN_PUBLIC_KEY=
RAGFLOW_CHAT_URL=http://127.0.0.1:8080/yuebai-workbench/
CONTENT_ASSET_BASE_URL=http://127.0.0.1:8765
CONTENT_ASSET_URL=/content-assets-service/docs
CONTENT_ASSET_HOST=127.0.0.1
CONTENT_ASSET_PORT=8767
CONTENT_ASSET_APP_DIR=/opt/yuebai-ai-platform/current/apps/content-assets-console
CONTENT_ASSET_CONFIG_PATH=/opt/yuebai-ai-platform/current/apps/content-assets-console/config.server.local.yml
CONTENT_ASSET_VENV_DIR=/opt/yuebai-ai-platform/venvs/content-assets-console
CONTENT_ASSET_PYTHON_BIN=/opt/yuebai-ai-platform/venvs/content-assets-console/bin/python
REVIEW_RUN_DIR=/opt/yuebai-ai-platform/data/knowledge-governance/review-runs/current
PLATFORM_CONFIG_PATH=/opt/yuebai-ai-platform/current/config/platform.json
FRONTEND_DIST=/opt/yuebai-ai-platform/current/dist
